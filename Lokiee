<script>
// ── UTILS ──
function sanitize(s){ return String(s).replace(/[<>"'&]/g,'').trim(); }
function isEmail(e){ return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e); }
async function sha256(s){
  const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(s));
  return Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,'0')).join('');
}
function uid(){
  const c='ABCDEFGHJKMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789';
  return 'LK-'+Array.from({length:10},()=>c[Math.floor(Math.random()*c.length)]).join('');
}
function toast(msg,type=''){
  const t=document.getElementById('toast');
  t.textContent=msg; t.className='toast-el show '+type;
  setTimeout(()=>t.className='toast-el',3500);
}

// ── PAGE ROUTER ──
function goto(pg){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+pg).classList.add('active');
  window.scrollTo(0,0);
  if(pg==='dashboard') loadDash();
}

function scrollTo2(id){
  const el=document.getElementById(id);
  if(el) el.scrollIntoView({behavior:'smooth'});
}

// ── SIGNUP ──
function togglePw(id,btn){
  const i=document.getElementById(id);
  i.type=i.type==='password'?'text':'password';
  btn.textContent=i.type==='password'?'👁':'🙈';
}
document.addEventListener('input',function(e){
  if(e.target.id!=='fpass') return;
  const v=e.target.value;
  const bar=document.getElementById('strBar');
  const txt=document.getElementById('strTxt');
  bar.className='str-fill';
  if(!v){txt.textContent='';return;}
  const strong=v.length>=10&&/[A-Z]/.test(v)&&/[0-9]/.test(v);
  const med=v.length>=6;
  if(strong){bar.classList.add('strong');txt.className='str-txt strong';txt.textContent='Strong';}
  else if(med){bar.classList.add('med');txt.className='str-txt med';txt.textContent='Medium';}
  else{bar.classList.add('weak');txt.className='str-txt weak';txt.textContent='Weak';}
});

async function handleSignup(){
  ['fnameErr','femailErr','fpassErr','fconfirmErr'].forEach(id=>document.getElementById(id).classList.remove('show'));
  document.querySelectorAll('#page-signup .form-input').forEach(i=>i.classList.remove('err'));
  let ok=true;
  const name=sanitize(document.getElementById('fname').value);
  const email=sanitize(document.getElementById('femail').value);
  const pass=document.getElementById('fpass').value;
  const conf=document.getElementById('fconfirm').value;
  const terms=document.getElementById('fterms').checked;
  if(name.length<2){showErr('fnameErr','fname');ok=false;}
  if(!isEmail(email)){showErr('femailErr','femail');ok=false;}
  if(pass.length<8){showErr('fpassErr','fpass');ok=false;}
  if(pass!==conf){showErr('fconfirmErr','fconfirm');ok=false;}
  if(!terms){toast('Please accept the terms to continue.','err');return;}
  if(!ok) return;
  const btn=document.getElementById('signupBtn');
  btn.disabled=true;
  document.getElementById('signupBtnTxt').textContent='Creating account...';
  document.getElementById('signupBtnIco').textContent='⏳';
  const hash=await sha256(pass);
  const id=uid();
  const ref='LOKIE-'+id.replace('LK-','');
  const users=JSON.parse(localStorage.getItem('lk_users')||'[]');
  if(users.find(u=>u.email===email)){
    document.getElementById('femailErr').textContent='An account with this email already exists';
    showErr('femailErr','femail');
    btn.disabled=false;
    document.getElementById('signupBtnTxt').textContent='Create Account & Claim $5';
    document.getElementById('signupBtnIco').textContent='→';
    return;
  }
  const token=crypto.randomUUID?crypto.randomUUID():id+Date.now();
  const user={uid:id,name,email,passwordHash:hash,referralCode:ref,balance:0,transactions:[],withdrawals:[],referrals:0,refEarnings:0,joinedAt:new Date().toISOString(),sessionToken:token};
  users.push(user);
  localStorage.setItem('lk_users',JSON.stringify(users));
  localStorage.setItem('lk_session',JSON.stringify({uid:id,sessionToken:token,email,name}));
  processReferralReward(id);
  setTimeout(()=>{
    document.getElementById('formState').style.display='none';
    document.getElementById('successState').classList.add('show');
  },700);
}
function showErr(errId,inputId){
  document.getElementById(errId).classList.add('show');
  document.getElementById(inputId).classList.add('err');
}

// ── DASHBOARD ──
let CU=null;
function loadDash(){
  const s=localStorage.getItem('lk_session');
  if(!s){goto('signup');return;}
  const sess=JSON.parse(s);
  const users=JSON.parse(localStorage.getItem('lk_users')||'[]');
  CU=users.find(u=>u.uid===sess.uid&&u.sessionToken===sess.sessionToken);
  if(!CU){goto('signup');return;}
  renderSidebar();
  renderOverview();
}
function saveUser(){
  const users=JSON.parse(localStorage.getItem('lk_users')||'[]');
  const i=users.findIndex(u=>u.uid===CU.uid);
  if(i!==-1){users[i]=CU;localStorage.setItem('lk_users',JSON.stringify(users));}
}
function renderSidebar(){
  const init=CU.name.split(' ').map(n=>n[0]).join('').toUpperCase().slice(0,2);
  document.getElementById('sbAv').textContent=init;
  document.getElementById('sbName').textContent=CU.name;
  document.getElementById('sbEmail').textContent=CU.email;
}
function renderOverview(){
  const bal=CU.balance||0;
  const txns=CU.transactions||[];
  const wds=CU.withdrawals||[];
  const earned=txns.filter(t=>t.type==='earn').reduce((a,b)=>a+b.amount,0);
  const withdrawn=wds.reduce((a,b)=>a+b.amount,0);
  const pct=Math.min(100,Math.round((bal/50)*100));
  document.getElementById('balDisplay').textContent='$'+bal.toFixed(2);
  document.getElementById('balSub').textContent=bal>=50?'Ready to withdraw!':'$'+(50-bal).toFixed(2)+' more to unlock withdrawal';
  document.getElementById('progFill').style.width=pct+'%';
  document.getElementById('progPct').textContent=pct+'%';
  document.getElementById('totalEarned').textContent='$'+earned.toFixed(2);
  document.getElementById('totalWd').textContent='$'+withdrawn.toFixed(2);
  document.getElementById('purchCnt').textContent=txns.filter(t=>t.type==='earn').length;
  document.getElementById('modalBal').textContent='$'+bal.toFixed(2);
  document.getElementById('wdBtn').disabled=bal<50;
  const base=window.location.origin+window.location.pathname;
  const ref=base+'?ref='+CU.referralCode;
  document.getElementById('refLink').value=ref;
  document.getElementById('refLink2').value=ref;
  document.getElementById('refCnt').textContent=CU.referrals||0;
  document.getElementById('refCnt2').textContent=CU.referrals||0;
  document.getElementById('refEarned').textContent='$'+(CU.refEarnings||0).toFixed(0);
  document.getElementById('refEarned2').textContent='$'+(CU.refEarnings||0).toFixed(2);
  renderTbl('recentTbl',[...txns].reverse().slice(0,5),'recentCnt',true);
  renderTbl('txnTbl',[...txns].reverse(),'txnCnt',true);
  renderWdTbl();
}
function renderTbl(id,txns,cntId,isTxn){
  document.getElementById(cntId).textContent=txns.length;
