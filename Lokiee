  }
  el.innerHTML='<div class="tbl-wrap"><table><thead><tr><th>Type</th><th>Description</th><th>Amount</th><th>Status</th><th>Date</th></tr></thead><tbody>'+
    txns.map(t=>`<tr><td>${t.type==='earn'?'💰 Reward':'🏦 Withdrawal'}</td><td>${sanitize(t.description)}</td><td class="td-amt ${t.type==='earn'?'pos':'neg'}">${t.type==='earn'?'+':'−'}$${t.amount.toFixed(2)}</td><td><span class="status-badge verified">✓ ${t.status}</span></td><td>${new Date(t.date).toLocaleDateString()}</td></tr>`).join('')+
  '</tbody></table></div>';
}
