function submitWd(){
  const m=document.getElementById('wdMethod').value;
  const w=document.getElementById('wdWalletInput').value.trim();
  if(!m){toast('Please select a withdrawal method','err');return;}
  if(!w){toast('Please enter your wallet or account details','err');return;}
  if((CU.balance||0)<50){toast('Insufficient balance','err');return;}
  const wd={method:m==='bank'?'Bank Transfer':m==='usdt'?'USDT':'Bitcoin',destination:sanitize(w),amount:CU.balance,status:'Pending',date:new Date().toISOString()};
  const txn={type:'withdrawal',description:'Withdrawal — '+wd.method,amount:CU.balance,status:'Pending',date:new Date().toISOString()};
  if(!CU.withdrawals) CU.withdrawals=[];
  if(!CU.transactions) CU.transactions=[];
  CU.withdrawals.push(wd);
  CU.transactions.push(txn);
  CU.balance=0;
  saveUser();
  closeModal();
  renderOverview();
  toast('✅ Withdrawal requested! Processing within 24 hours.','ok');
}

