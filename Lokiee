    el.innerHTML='<div class="empty-box"><div class="empty-ico">💰</div><div class="empty-h">No transactions yet</div><div class="empty-sub">Buy a prop firm through <a onclick="showDash(\'firms\',null)">Prop Firms</a> to earn your first $5.</div></div>';
