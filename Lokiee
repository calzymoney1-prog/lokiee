// ── SIGNIN ──
async function handleSignin(){
  ['siemailErr','sipassErr'].forEach(id=>document.getElementById(id).classList.remove('show'));
  document.querySelectorAll('#page-signin .form-input').forEach(i=>i.classList.remove('err'));
  const email=sanitize(document.getElementById('siemail').value);
  const pass=document.getElementById('sipass').value;
  if(!isEmail(email)){document.getElementById('siemailErr').classList.add('show');document.getElementById('siemail').classList.add('err');return;}
  if(!pass){document.getElementById('sipassErr').textContent='Please enter your password';document.getElementById('sipassErr').classList.add('show');document.getElementById('sipass').classList.add('err');return;}
  const btn=document.getElementById('signinBtn');
  btn.disabled=true;
  document.getElementById('signinBtnTxt').textContent='Signing in...';
  const hash=await sha256(pass);
  const users=JSON.parse(localStorage.getItem('lk_users')||'[]');
  const user=users.find(u=>u.email===email&&u.passwordHash===hash);
  if(!user){
    document.getElementById('sipassErr').textContent='Incorrect email or password';
    document.getElementById('sipassErr').classList.add('show');
    document.getElementById('sipass').classList.add('err');
    btn.disabled=false;
    document.getElementById('signinBtnTxt').textContent='Sign In';
    return;
  }
  const token=crypto.randomUUID?crypto.randomUUID():user.uid+Date.now();
  user.sessionToken=token;
  const idx=users.findIndex(u=>u.uid===user.uid);
  users[idx]=user;
  localStorage.setItem('lk_users',JSON.stringify(users));
  localStorage.setItem('lk_session',JSON.stringify({uid:user.uid,sessionToken:token,email:user.email,name:user.name}));
  CU=user;
  goto('dashboard');
}

// ── REFERRAL SIGNUP REWARD ($0.05) ──
// When page loads with ?ref= param, store referral code
// When new user signs up, credit $0.05 to referrer
function checkReferral(){
  const params=new URLSearchParams(window.location.search);
  const ref=params.get('ref');
  if(ref) sessionStorage.setItem('lk_ref',ref);
}
function processReferralReward(newUserUid){
  const ref=sessionStorage.getItem('lk_ref');
  if(!ref) return;
  const users=JSON.parse(localStorage.getItem('lk_users')||'[]');
  const referrer=users.find(u=>u.referralCode===ref&&u.uid!==newUserUid);
  if(!referrer) return;
  referrer.balance=(referrer.balance||0)+0.05;
  referrer.referrals=(referrer.referrals||0)+1;
  referrer.refEarnings=(referrer.refEarnings||0)+0.05;
  const txn={type:'earn',description:'Referral Signup Bonus',amount:0.05,status:'Verified',date:new Date().toISOString()};
  if(!referrer.transactions) referrer.transactions=[];
  referrer.transactions.push(txn);
  const idx=users.findIndex(u=>u.uid===referrer.uid);
  users[idx]=referrer;
  localStorage.setItem('lk_users',JSON.stringify(users));
  sessionStorage.removeItem('lk_ref');
}

// ── COUNT-UP ANIMATION ──
function animateCount(el, target, prefix='', suffix='', duration=2000){
  const start=performance.now();
  const isDecimal=target%1!==0;
  function step(now){
    const elapsed=now-start;
    const progress=Math.min(elapsed/duration,1);
    const ease=1-Math.pow(1-progress,3);
    const current=isDecimal?(Math.round(ease*target*10)/10):(Math.round(ease*target));
    el.textContent=prefix+(isDecimal?current.toFixed(1):current.toLocaleString())+suffix;
    if(progress<1) requestAnimationFrame(step);
    else el.textContent=prefix+(isDecimal?target.toFixed(1):target.toLocaleString())+suffix;
  }
  requestAnimationFrame(step);
}
function initCounters(){
  const statsRow=document.querySelector('.stats-row');
  if(!statsRow) return;
  const obs=new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(e.isIntersecting){
        animateCount(document.getElementById('cnt1'),1247,'','',2200);
        animateCount(document.getElementById('cnt2'),48,'$','K+',2000);
        animateCount(document.getElementById('cnt3'),4,'','+',1600);
        animateCount(document.getElementById('cnt4'),4.9,'','★',2400);
        obs.disconnect();
      }
    });
  },{threshold:0.3});
  obs.observe(statsRow);
}

// Run on load
checkReferral();
initCounters();

